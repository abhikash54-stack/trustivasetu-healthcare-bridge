generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String
  role                 UserRole              @default(TEAM_MEMBER)
  isActive             Boolean               @default(true)
  mustChangePassword   Boolean               @default(false)
  metadata             Json?
  phone                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  createdById          String?
  reportingManagerId   String?
  auditLogs            AuditLog[]
  managedClinics       Clinic[]              @relation("ClinicRM")
  createdLeads         Lead[]                @relation("LeadCreatedBy")
  notifications        Notification[]
  targets              Target[]
  createdBy            User?                 @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers         User[]                @relation("UserCreatedBy")
  reportingManager     User?                 @relation("UserReporting", fields: [reportingManagerId], references: [id])
  reportingTeam        User[]                @relation("UserReporting")
  clinicAssignments    UserClinic[]
  regionAssignments    UserRegion[]
  employeeProfile      EmployeeProfile?
  salaryStructure      SalaryStructure?
  attendances          Attendance[]
  approvedAttendances  Attendance[]          @relation("AttendanceApprovals")
  createdHolidays      Holiday[]
  expenses             Expense[]             @relation("UserExpenses")
  approvedExpenses     Expense[]             @relation("ExpenseApprovals")
  appointmentLetters   AppointmentLetter[]
  tabSessions          TabSession[]
  leaveRequests        LeaveRequest[]
  approvedLeaveRequests LeaveRequest[]       @relation("LeaveApprovals")
}

model TabSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Region {
  id              String       @id @default(cuid())
  name            String       @unique
  code            String       @unique
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  clinics         Clinic[]
  targets         Target[]
  userAssignments UserRegion[]
}

model UserRegion {
  userId   String
  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, regionId])
}

model UserClinic {
  userId   String
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, clinicId])
}

model Clinic {
  id                  String       @id @default(cuid())
  externalId          String?      @unique
  name                String
  address             String
  accountNumber       String?
  contactPerson       String
  contactNumber       String
  email               String?
  businessPotential   Float?
  isActive            Boolean      @default(true)
  portalAccessSent    Boolean      @default(false)
  portalAccessSentAt  DateTime?
  reportEmails        String[]
  onboardedAt         DateTime     @default(now())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  regionId            String
  assignedRMId        String?
  hospitalType        String?
  metadata            Json?
  assignedRM        User?        @relation("ClinicRM", fields: [assignedRMId], references: [id])
  region            Region       @relation(fields: [regionId], references: [id])
  leads             Lead[]
  targets           Target[]
  userAssignments   UserClinic[]
  schemes           ClinicScheme[]

  @@index([regionId])
  @@index([assignedRMId])
}

model Lender {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
}

model Lead {
  id              String     @id @default(cuid())
  externalId      String?    @unique
  applicantName   String
  phone           String?
  email           String?
  amount          Float
  status          LeadStatus @default(PENDING)
  approvedAmount  Float?
  disbursedAmount Float?
  applicationDate DateTime   @default(now())
  approvalDate    DateTime?
  disbursalDate   DateTime?
  remarks         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  clinicId        String
  lenderId        String?
  createdById     String?
  metadata        Json?
  losEnquiryId      String?    @unique
  enquiryType       String?
  treatmentName     String?
  treatmentCategory String?
  utrNumber         String?
  nachStatus        String?
  agreementSigned   Boolean    @default(false)
  rejectionReason   String?
  clinic          Clinic     @relation(fields: [clinicId], references: [id])
  createdBy       User?      @relation("LeadCreatedBy", fields: [createdById], references: [id])
  lender          Lender?    @relation(fields: [lenderId], references: [id])

  @@index([clinicId])
  @@index([lenderId])
  @@index([createdById])
  @@index([status])
  @@index([applicationDate])
  @@index([createdAt])
  @@index([nachStatus])
  @@index([agreementSigned])
}

model Target {
  id              String   @id @default(cuid())
  year            Int
  month           Int
  leadsTarget     Int      @default(0)
  disbursalTarget Float    @default(0)
  userId          String?
  regionId        String?
  clinicId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  clinic          Clinic?  @relation(fields: [clinicId], references: [id])
  region          Region?  @relation(fields: [regionId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])

  @@unique([year, month, regionId, userId, clinicId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@index([entity, action, entityId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model WebhookEvent {
  id          String        @id @default(cuid())
  source      String        @default("external")
  event       String
  entity      WebhookEntity
  status      WebhookStatus @default(RECEIVED)
  payload     Json
  response    String?
  error       String?
  createdAt   DateTime      @default(now())
  processedAt DateTime?

  @@index([event])
  @@index([entity])
  @@index([status])
  @@index([createdAt])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  REGIONAL_MANAGER
  TEAM_MEMBER
  CLINIC_USER
}

enum LeadStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
  CANCELLED
  DOCS_PENDING
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum WebhookEntity {
  LEAD
  CLINIC
  USER
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum AttendanceType {
  PRESENT
  LEAVE
  OUTSTATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  PL
  CL
  MEDICAL
  UNPLANNED
}

model PatientEnquiry {
  id                     String    @id @default(cuid())
  source                 String    // 'WEBSITE_FORM' | 'INCOMPLETE_LEAD'
  applicantName          String?
  mobile                 String?
  email                  String?
  hospitalName           String?
  clinicId               String?
  treatmentName          String?
  loanAmount             Float?
  panNumber              String?
  panVerified            Boolean   @default(false)
  aadharNumber           String?
  employmentType         String?
  monthlyIncome          Float?
  companyName            String?
  currentHouseNo         String?
  currentStreet          String?
  currentLandmark        String?
  currentPinCode         String?
  currentCity            String?
  currentState           String?
  permanentSameAsCurrent Boolean   @default(false)
  permanentPinCode       String?
  permanentCity          String?
  permanentState         String?
  assignedRegion         String?
  assignedRmId           String?
  assignedManagerId      String?
  assignedById           String?
  assignedAt             DateTime?
  status                 String    @default("NEW")
  convertedLeadId        String?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status])
  @@index([assignedRmId])
  @@index([assignedManagerId])
  @@index([createdAt])
}

model ProviderEnquiry {
  id                String    @id @default(cuid())
  source            String    // 'WEBSITE_FORM' | 'MANUAL'
  clinicName        String?
  contactPerson     String?
  mobile            String?
  email             String?
  address           String?
  pinCode           String?
  city              String?
  state             String?
  region            String?
  treatmentTypes    String?
  ifscCode          String?
  bankName          String?
  branchName        String?
  accountNumber     String?
  assignedRegion    String?
  assignedRmId      String?
  assignedManagerId String?
  assignedById      String?
  assignedAt        DateTime?
  status            String    @default("NEW")
  convertedClinicId String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([assignedRmId])
  @@index([assignedManagerId])
  @@index([createdAt])
}

model RegionMapping {
  id                String   @id @default(cuid())
  regionName        String   @unique
  cities            String[]
  pinCodes          String[]
  states            String[]
  assignedRmId      String?
  assignedManagerId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum WorkingType {
  FULL_DAY
  HALF_DAY
}

model EmployeeProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth           DateTime? @db.Date
  dateOfJoining         DateTime? @db.Date
  marriageAnniversary   DateTime? @db.Date
  designation           String?
  department            String?
  probationEndDate      DateTime? @db.Date
  exitDate              DateTime? @db.Date
  photoUrl              String?
  policyAcknowledgedAt  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model SalaryStructure {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grossSalary   Float
  tds           Float    @default(0)
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Attendance {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime       @db.Date
  attendanceType  AttendanceType
  leaveType       LeaveType?
  workingType     WorkingType    @default(FULL_DAY)
  outstationCity  String?
  timeIn          String?
  latitude        Float?
  longitude       Float?
  locationName    String?
  notes           String?
  approvalStatus  ApprovalStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  approvalToken   String?        @unique
  approvedBy      User?          @relation("AttendanceApprovals", fields: [approvedById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model OtpToken {
  id           String    @id @default(cuid())
  email        String
  emailOtp     String
  purpose      String    @default("PASSWORD_RESET")
  attempts     Int       @default(0)
  blockedUntil DateTime?
  expiresAt    DateTime
  verified     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
  @@index([verified])
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([date])
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

model Expense {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("UserExpenses", fields: [userId], references: [id], onDelete: Cascade)
  title           String
  periodType      String        @default("MONTHLY")
  periodStart     DateTime      @db.Date
  periodEnd       DateTime      @db.Date
  status          ExpenseStatus @default(DRAFT)
  totalAmount     Float         @default(0)
  approvedAmount  Float?
  rejectionReason String?
  approvedById    String?
  approvedBy      User?         @relation("ExpenseApprovals", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  submittedAt     DateTime?
  notes           String?
  items           ExpenseItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model ExpenseItem {
  id           String   @id @default(cuid())
  expenseId    String
  expense      Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  category     String
  description  String
  fromLocation String?
  toLocation   String?
  distanceKm   Float?
  amount       Float
  billUrl      String?
  billName     String?
  clientName   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expenseId])
}

enum AppointmentLetterStatus {
  PENDING_ACKNOWLEDGEMENT
  ACKNOWLEDGED
}

model AppointmentLetter {
  id                          String                  @id @default(cuid())
  userId                      String
  user                        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  letterNumber                String                  @unique
  version                     Int                     @default(1)
  status                      AppointmentLetterStatus @default(PENDING_ACKNOWLEDGEMENT)
  isArchived                  Boolean                 @default(false)
  employeeName                String
  designation                 String?
  department                  String?
  dateOfJoining               DateTime?               @db.Date
  employmentType              String                  @default("PROBATION")
  reportingManagerName        String?
  reportingManagerDesignation String?
  workLocation                String?
  grossSalary                 Float?
  salaryBreakdown             Json?
  travelRatePerKm             Float?
  monthlyExpenseCap           Float?
  acknowledgedAt              DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt

  @@index([userId])
  @@index([status])
}
model LeaveRequest {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            LeaveType
  fromDate        DateTime       @db.Date
  toDate          DateTime       @db.Date
  reason          String
  status          ApprovalStatus @default(PENDING)
  approverComment String?
  approvedById    String?
  approvedBy      User?          @relation("LeaveApprovals", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SchemeTemplate {
  id            String         @id @default(cuid())
  name          String         @unique
  tenure        Int
  advanceEmi    Int
  balanceEmi    Int
  isActive      Boolean        @default(true)
  isCustom      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clinicSchemes ClinicScheme[]
}

model RolePermission {
  id        String   @id @default(cuid())
  role      String
  module    String
  action    String
  granted   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, module, action])
  @@index([role])
}

model ClinicScheme {
  id                   String         @id @default(cuid())
  clinicId             String
  schemeTemplateId     String
  hospitalSubventionPct Float
  gstOnSubvention      Float          @default(18)
  subventionGstType    String         @default("EXCLUDED")
  totalSubventionPct   Float
  processingFeePct     Float          @default(0)
  processingFeeGstType String         @default("EXCLUDED")
  gstOnPF              Float          @default(18)
  isActive             Boolean        @default(true)
  agreedAt             DateTime       @default(now())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  clinic               Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  schemeTemplate       SchemeTemplate @relation(fields: [schemeTemplateId], references: [id])

  @@unique([clinicId, schemeTemplateId])
  @@index([clinicId])
}

model RecycleBin {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  entityName String
  deletedBy  String
  deletedAt  DateTime @default(now())
  snapshot   Json

  @@index([entityType])
  @@index([deletedAt])
}