# ============================================================
# Trustiva LMS — Environment Variables Reference
# Copy to .env.local for development (never commit real values)
# Set in Vercel Dashboard → Settings → Environment Variables for production
# ============================================================

# ------------------------------------------------------------
# DATABASE (PostgreSQL — Neon recommended for production)
# ------------------------------------------------------------
# Pooled connection (used by Prisma at runtime via PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Direct connection (used by Prisma CLI: migrate, db push, db pull)
# Neon: same host but port 5432, no pgbouncer param
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ------------------------------------------------------------
# NEXT AUTH
# ------------------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-long-random-secret-min-32-chars"

# Public URL of the deployment (no trailing slash)
NEXTAUTH_URL="https://lms.trustivasetu.com"

# ------------------------------------------------------------
# WEBHOOKS & LOS INTEGRATION
# ------------------------------------------------------------
# Secret verified via x-webhook-secret header on inbound webhook POSTs
# Generate: openssl rand -hex 32
WEBHOOK_SECRET="replace-with-strong-webhook-secret"

# LOS Healthcare Console → LMS sync key (same value set in LOS as NEXT_PUBLIC_LOS_API_KEY)
# Generate: openssl rand -hex 32
LOS_API_KEY="replace-with-strong-los-api-key"

# ------------------------------------------------------------
# VERCEL BLOB STORAGE (appointment letters, employee photos)
# ------------------------------------------------------------
# Create at: Vercel Dashboard → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ------------------------------------------------------------
# SMTP (email notifications — OTP, approvals, appointment letters)
# ------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user@trustivasetu.com"
SMTP_PASS="your-smtp-app-password"
FROM_EMAIL="\"Trustiva Setu LMS\" <noreply@trustivasetu.com>"

# ------------------------------------------------------------
# MSG91 SMS GATEWAY (OTP delivery for public lead form)
# ------------------------------------------------------------
# Sign up at https://msg91.com — copy Auth Key from dashboard
MSG91_AUTH_KEY="your-msg91-auth-key"

# DLT-registered template ID (required for Indian regulatory compliance)
MSG91_TEMPLATE_ID="your-msg91-otp-template-id"

# ------------------------------------------------------------
# OTP BYPASS — DEVELOPMENT / STAGING ONLY
# ------------------------------------------------------------
# ⚠ NEVER set to "true" in production — skips SMS and accepts 123456 as any OTP
# ENABLE_OTP_BYPASS="true"

# ------------------------------------------------------------
# OPTIONAL: LOS Healthcare Console base URL
# ------------------------------------------------------------
# LOS_BASE_URL="https://los.trustivasetu.com"
