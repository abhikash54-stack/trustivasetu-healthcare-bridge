# Local dev: copy to .env.development.local (see docs/DEPLOY.md)
# DATABASE_URL="postgresql://trustiva:trustiva@127.0.0.1:5432/trustiva_lms?schema=public"

# Production (Vercel / analytics.trustivasetu.com)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"
NEXTAUTH_URL="https://analytics.trustivasetu.com"

# NextAuth
NEXTAUTH_SECRET="generate-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Webhook sync (external systems POST with header x-webhook-secret)
WEBHOOK_SECRET="generate-a-strong-webhook-secret"

# LOS Healthcare Console → LMS sync (same key in LOS app as NEXT_PUBLIC_LOS_API_KEY)
LOS_API_KEY="generate-a-strong-los-api-key"

# SMTP (email notifications — attendance approval, expense approval, etc.)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
FROM_EMAIL="\"Trustiva Setu LMS\" <noreply@trustivasetu.com>"

# MSG91 SMS gateway (OTP delivery)
# Sign up at https://msg91.com — copy your Auth Key from the dashboard
# MSG91_TEMPLATE_ID is optional but recommended for DLT compliance in India
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-msg91-otp-template-id"
